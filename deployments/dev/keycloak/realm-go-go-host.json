{
  "loginTheme": "go-go-host",
  "realm": "go-go-host",
  "enabled": true,
  "displayName": "go-go-host local dev",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      { "name": "go-go-host-admin", "description": "Platform administrator for local go-go-host development" }
    ]
  },
  "clients": [
    {
      "clientId": "go-go-host-dashboard",
      "name": "go-go-host Dashboard",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://127.0.0.1:5173/app/auth/callback",
        "http://localhost:5173/app/auth/callback",
        "http://127.0.0.1:8080/app/auth/callback",
        "http://localhost:8080/app/auth/callback"
      ],
      "webOrigins": [
        "http://127.0.0.1:5173",
        "http://localhost:5173",
        "http://127.0.0.1:8080",
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://127.0.0.1:5173/app##http://localhost:5173/app##http://127.0.0.1:8080/app##http://localhost:8080/app"
      }
    },
    {
      "clientId": "go-go-host-cli",
      "name": "go-go-host CLI",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oauth2.device.code.lifespan": "600",
        "oauth2.device.polling.interval": "5"
      }
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@example.test",
      "firstName": "Alice",
      "lastName": "Developer",
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }]
    },
    {
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@example.test",
      "firstName": "Bob",
      "lastName": "Builder",
      "credentials": [{ "type": "password", "value": "bob", "temporary": false }]
    },
    {
      "username": "platform-admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@example.test",
      "firstName": "Platform",
      "lastName": "Admin",
      "realmRoles": ["go-go-host-admin"],
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }]
    }
  ]
}
